{
  "extends": "solhint:recommended",
  "rules": {
    "compiler-version": ["error", "^0.8.19"],
    "const-name-snakecase": "error",
    "contract-name-camelcase": "error",
    "event-name-camelcase": "error",
    "func-name-mixedcase": "error",
    "use-natspec": "off",
    "no-console": "off",
    "no-empty-blocks": "off"
  }
}